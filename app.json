{
  "expo": {
    "name": "FreePace Piano",
    "slug": "sightreading",
    "scheme": "sightreading",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/2422c0a7-6818-4a29-8510-40db3553c17c"
    },
    "ios": {
      "bundleIdentifier": "com.freepacepiano.app",
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "האפליקציה צריכה גישה למיקרופון כדי לזהות את הנגינה שלך"
      }
    },
    "android": {
      "package": "com.freepacepiano.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-notifications",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "2422c0a7-6818-4a29-8510-40db3553c17c"
      }
    },
    "owner": "assafbiton"
  }
}
